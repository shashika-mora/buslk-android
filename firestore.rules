rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // USERS COLLECTION
    match /users/{userId} {
      allow read: if request.auth != null;
      
      // Allow write if it's the user's own document, but prevent spoofing of
      // privileged fields. Clients MUST NOT be able to self-assign a role or
      // inflate their own gamification points.
      //
      // Security Note: 'role' changes are blocked entirely (RBAC protection).
      // 'points' changes are blocked here; point awards MUST go through
      // TripRepository.reportCrowdLevel() → FieldValue.increment() on the server,
      // or via Cloud Functions post-MVP. A malicious client cannot set points=99999.
      //
      // We allow creation (when the document doesn't exist yet) so that
      // AuthRepository.syncUserToFirestore() can write the initial user profile.
      allow write: if request.auth != null && request.auth.uid == userId && 
                   (!exists(/databases/$(database)/documents/users/$(userId)) ||
                   !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'points']));
    }

    // ROUTES, BUSES & BROADCASTS COLLECTIONS (Admin Only Writes)
    match /routes/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Admin";
    }
    match /buses/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Admin";
    }
    match /broadcasts/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Admin";
    }

    // TRIPS, FEEDBACK, LOST AND FOUND, SUPPORT (Users can create/update their own)
    match /trips/{document=**} {
      allow read, create: if request.auth != null;
      allow update, delete: if request.auth != null && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Admin" || resource.data.userId == request.auth.uid);
    }
    match /feedback/{document=**} {
      allow read, create: if request.auth != null;
      allow update, delete: if request.auth != null && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Admin" || resource.data.userId == request.auth.uid);
    }
    match /lost_and_found/{document=**} {
      allow read, create: if request.auth != null;
      allow update, delete: if request.auth != null && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Admin" || resource.data.userId == request.auth.uid);
    }
    match /support_threads/{document=**} {
      allow read, create: if request.auth != null;
      allow update, delete: if request.auth != null && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Admin" || resource.data.userId == request.auth.uid);
    }
  }
}
